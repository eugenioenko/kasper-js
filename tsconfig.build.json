{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationDir": "./dist/types",
    "noEmit": false,
    "paths": {
      "@kasper/*": ["src/*"],
      "token": ["src/types/token.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "spec"]
}
