<template>
  <div class="example">
    <h2>Examples</h2>

    <section>
      <h3>Signal</h3>
      <p>Count: <strong>{{count.value}}</strong></p>
      <button @on:click="increment()">Increment</button>
      <button @on:click="reset()">Reset</button>
    </section>

    <section>
      <h3>If / Else</h3>
      <p @if="count.value > 5" class="badge badge--high">Count is greater than 5</p>
      <p @elseif="count.value > 0" class="badge badge--mid">Count is between 1 and 5</p>
      <p @else class="badge badge--zero">Count is zero</p>
    </section>

    <section>
      <h3>Each</h3>
      <ul>
        <li @each="item of items.value">{{item}}</li>
      </ul>
      <button @on:click="addItem()">Add Item</button>
    </section>
  </div>
</template>

<script>
import { Component, signal } from 'kasper-js';

export class Example extends Component {
  count = signal(0);
  items = signal(['Apple', 'Banana', 'Cherry']);

  increment() {
    this.count.value++;
  }

  reset() {
    this.count.value = 0;
  }

  addItem() {
    const next = ['Date', 'Elderberry', 'Fig', 'Grape', 'Honeydew'];
    const i = this.items.value.length - 3;
    this.items.value = [...this.items.value, next[i % next.length]];
  }
}
</script>

