{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "sourceMap": true,
    "outDir": "./dist/",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": false,
    "strictFunctionTypes": true,
    "alwaysStrict": true,
    "baseUrl": ".",
    "paths": {
      "@kasper/*": ["src/*"]
    },
    "esModuleInterop": true,
    "types": ["vitest/globals", "node"]
  },
  "include": ["src", "spec"],
  "exclude": ["node_modules", "dist"]
}
