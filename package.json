{
  "name": "kasper-js",
  "version": "0.3.4",
  "description": "A lightweight component framework with fine-grained Signal-based reactivity. No virtual DOM. No magic compiler. Just components, signals, and surgical DOM updates",
  "main": "./dist/kasper.js",
  "module": "./dist/kasper.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/kasper.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "scripts": {
    "dev": "vite build --mode development --watch",
    "build": "vite build --mode development && vite build && tsc -p tsconfig.build.json",
    "build:dev": "vite build --mode development",
    "type-check": "tsc --noEmit",
    "lint": "eslint src",
    "generator": "node tools/generator.js",
    "cli": "node dist/@script",
    "test": "vitest run",
    "test:watch": "vitest",
    "sandbox": "pnpm --filter project-sandbox dev",
    "demo": "pnpm --filter create-kasper-app --filter sandbox dev",
    "docs": "pnpm --filter docs-web dev",
    "docs:build": "pnpm --filter docs-web build",
    "playground": "npx serve . -l 3000"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "javascript",
    "framework",
    "signals",
    "reactivity",
    "components",
    "vite"
  ],
  "author": "eugenioenko",
  "license": "MIT",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.12.7",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.3",
    "happy-dom": "^20.8.3",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.57.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.18"
  }
}