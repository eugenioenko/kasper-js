{
  "name": "kasper",
  "version": "1.0.0",
  "description": "A javascript template parser",
  "main": "./dist/kasper.js",
  "module": "./dist/kasper.esm.js",
  "exports": {
    ".": {
      "import": "./dist/kasper.esm.js",
      "require": "./dist/kasper.js"
    }
  },
  "packageManager": "pnpm@10",
  "scripts": {
    "dev": "vite build --mode development --watch",
    "build": "vite build --mode development && vite build",
    "build:dev": "vite build --mode development",
    "type-check": "tsc --noEmit",
    "lint": "eslint src",
    "generator": "node tools/generator.js",
    "cli": "node dist/@script",
    "test": "vitest run",
    "test:watch": "vitest",
    "sandbox": "pnpm --filter sandbox dev"
  },
  "keywords": [
    "javascript",
    "interpreter"
  ],
  "author": "eugenioenko",
  "license": "MIT",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.12.7",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.3",
    "happy-dom": "^20.8.3",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.57.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.18"
  }
}